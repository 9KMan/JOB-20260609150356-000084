# =============================================================
# NRG Clinic — Healthcare Integration Environment
# HIPAA: rotate secrets regularly. Never commit real values.
# =============================================================

# App
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://nrg:dev@localhost:5432/nrg_clinic
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Auth
JWT_SECRET=replace-me-with-32-byte-secret-rotate-quarterly
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# HIPAA
PHI_ENCRYPTION_KEY=base64:replace-with-32-byte-fernet-key=
AUDIT_LOG_RETENTION_DAYS=2555

# Charm Health (legacy EHR — source of migration)
CHARM_HEALTH_BASE_URL=https://api.charmhealth.com
CHARM_HEALTH_API_KEY=
CHARM_HEALTH_USERNAME=
CHARM_HEALTH_PASSWORD=

# Healthie (target EHR)
HEALTHIE_GRAPHQL_URL=https://api.gethealthie.com/graphql
HEALTHIE_API_KEY=
HEALTHIE_API_SECRET=

# DoseSpot (e-prescribing)
DOSESPOT_BASE_URL=https://api.dosespot.com/v14
DOSESPOT_API_KEY=
DOSESPOT_API_SECRET=
DOSESPOT_CLINIC_ID=

# LabCorp (lab integrations)
LABCORP_BASE_URL=https://api.labcorp.com
LABCORP_API_KEY=
LABCORP_ACCOUNT_ID=

# Stripe (billing)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Zoho CRM
ZOHO_CRM_BASE_URL=https://www.zohoapis.com/crm/v2
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REFRESH_TOKEN=

# n8n (workflow automation)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_URL=

# Keragon (HIPAA-compliant automation)
KERAGON_BASE_URL=https://api.keragon.com
KERAGON_API_KEY=
KERAGON_WEBHOOK_URL=

# Telehealth
TELEHEALTH_PROVIDER=doxy
DOXY_USERNAME=
DOXY_PASSWORD=

# Redis (queue)
REDIS_URL=redis://localhost:6379
